⠀⠀⠀⠀⠀⠉⠉⠉⣿⣇⣈⣆⠀⠳⠤⠀⠀⠀⠈⣇⡖⡍⠀⠠⣾⣿⡿⠇⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠛⠛⠛⢻⣷⣄⠀⠀⠀⠀⠁⠉⠀⠀⣠⣾⠟⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣀⣉⣿⣷⠲⠤⠤⠤⣤⣶⣿⣟⠁⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⢀⣴⣶⡿⠿⠛⠛⢋⢹⡦⣄⣀⡤⢿⢉⠛⠛⠿⣷⣦⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⣿⠏⠀⠀⠀⠀⢀⠇⠈⡇⠀⠀⠀⠘⡎⣆⠀⠀⠀⢻⣧⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠈⠿⣶⣶⣶⣶⣶⣾⣶⣾⣷⣶⣶⣶⣶⣷⣾⣷⣶⣶⣾⡿⠀⠀⠀⠀⠀"
    local logo_width=32
    local term_width=$(tput cols)
    local pad=$(( (term_width - logo_width) / 2 ))
    local padding=$(printf '%*s' "$pad" '')

    if [ -n "$(command -v lolcat)" ]; then
        while IFS= read -r line; do
            echo "${padding}${line}"
        done <<< "$logo" | lolcat
    else
        while IFS= read -r line; do
            echo -e "\033[1;0m${padding}${line}\033[0m"
        done <<< "$logo"
    fi
}
#print_logo
sleep 0.4 && neofetch --backend sixel --source /sdcard/eu.png
center() {
  termwidth=$(stty size | cut -d" " -f2)
  padding="$(printf '%0.1s' ={1..500})"
  printf '\033[1;31m<\033[38;5;27m%*.*s\033[0m \033[1;33m%s\033[0m \033[38;5;27m%*.*s\033[1;31m>\033[0m\n' 0 "$(((termwidth-4-${#1})/2))" "$padding" "$1" 0 "$(((termwidth-3-${#1})/2))" "$padding"
};center WhoFoss

#PS1 USER/ROOT
if [[ ${EUID} == 0 ]] ; then   
PS1='\[\e[31m\]┌──(\[\e[38;5;27;1m\]root\[\e[0;31m\])\[\e[38;5;27m\]┉\[\e[0;31m\][\[\e[38;5;27m\]${PWD/*\//}\[\e[0;31m\]]\n\[\e[31m\]╰─\[\e[91;1m\]#\[\e[0m\] '
else
PS1='\[\e[31m\]┌──(\[\e[38;5;27;1m\]WhoFoss\[\e[0;31m\])\[\e[38;5;27m\]┉\[\e[0;31m\][\[\e[38;5;27m\]${PWD/*\//}\[\e[0;31m\]]\n\[\e[31m\]╰─\[\e[38;5;27;1m\]>\[\e[0m\] '
fi
